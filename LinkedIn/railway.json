{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "python3 -m venv /opt/venv && /opt/venv/bin/pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "/opt/venv/bin/python3 app.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

